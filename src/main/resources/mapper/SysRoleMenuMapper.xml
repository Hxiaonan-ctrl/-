<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!-- namespace 必须与 Mapper 接口全类名完全一致 -->
<mapper namespace="com.example.crm.mapper.SysRoleMenuMapper">

    <!-- 批量插入角色-菜单关联（含创建时间） -->
    <insert id="batchInsert">
        INSERT INTO sys_role_menu (role_id, menu_id, create_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.roleId}, #{item.menuId}, NOW())
        </foreach>
    </insert>

    <!-- 根据角色ID删除所有关联菜单（RolePermissionService 必需） -->
    <delete id="deleteByRoleId">
        DELETE FROM sys_role_menu WHERE role_id = #{roleId}
    </delete>

    <!-- 可选：根据角色ID查询关联的菜单ID（用于回显已选菜单） -->
    <select id="selectMenuIdsByRoleId" resultType="java.lang.Long">
        SELECT menu_id FROM sys_role_menu WHERE role_id = #{roleId}
    </select>

</mapper>